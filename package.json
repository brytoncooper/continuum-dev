{
  "name": "@continuum-dev/source",
  "version": "0.3.0",
  "license": "MIT",
  "scripts": {
    "demo": "nx run demo:serve",
    "demo:api": "nx run demo-api:dev",
    "build:release-packages": "tsc --build packages/contract/tsconfig.lib.json packages/protocol/tsconfig.lib.json packages/runtime/tsconfig.lib.json packages/session/tsconfig.lib.json packages/core/tsconfig.lib.json packages/react/tsconfig.lib.json packages/prompts/tsconfig.lib.json packages/ai-connect/tsconfig.lib.json packages/ai-engine/tsconfig.lib.json packages/vercel-ai-sdk/tsconfig.lib.json packages/starter-kit/tsconfig.lib.json packages/starter-kit-ai/tsconfig.lib.json packages/ai-core/tsconfig.lib.json",
    "prepare:dist-packages": "node scripts/prepare-dist-packages.mjs",
    "verify:release-packages": "node scripts/verify-release-packages.mjs",
    "publish:public-packages": "npm run build:release-packages && npm run prepare:dist-packages && npm run verify:release-packages && npx nx release publish --groups=publicPackages"
  },
  "private": true,
  "devDependencies": {
    "@angular/common": "^20.3.17",
    "@angular/core": "^20.3.17",
    "@angular/forms": "^20.3.17",
    "@angular/platform-browser": "^20.3.17",
    "@eslint/js": "^9.8.0",
    "@nx/devkit": "22.5.1",
    "@nx/eslint": "22.5.0",
    "@nx/eslint-plugin": "22.5.0",
    "@nx/js": "22.5.0",
    "@nx/playwright": "^22.5.1",
    "@nx/vite": "22.5.0",
    "@nx/vitest": "22.5.0",
    "@nx/web": "22.5.0",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "20.19.9",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "4.0.9",
    "@vitest/ui": "4.0.9",
    "eslint": "~8.57.0",
    "eslint-plugin-playwright": "^1.6.2",
    "jiti": "2.4.2",
    "jsdom": "^28.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.5.0",
    "prettier": "^2.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "verdaccio": "^6.0.5",
    "vite": "^7.0.0",
    "vitest": "4.0.9",
    "wrangler": "^4.72.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
