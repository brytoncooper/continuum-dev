    "LICENSE*"
  ],
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@continuum-dev/contract": "^0.1.0",
    "@continuum-dev/session": "^0.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.0"
  },
  "nx": {
