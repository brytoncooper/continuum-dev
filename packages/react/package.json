{
  "name": "@continuum-dev/react",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "React bindings for the Continuum continuity runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brytoncooper/cooper-continuum.git",
    "directory": "packages/react"
  },
  "author": "CooperContinuum",
  "keywords": [
    "continuum",
    "ai",
    "ui",
    "continuity",
    "reconciliation",
    "react",
    "hooks",
    "provider"
  ],
  "type": "module",
  "sideEffects": false,
