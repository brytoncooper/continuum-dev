{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "../../dist/packages/session",
    "tsBuildInfoFile": "../../dist/packages/session/tsconfig.lib.tsbuildinfo",
    "types": ["node"],
    "emitDeclarationOnly": false
  },
  "exclude": [
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../protocol/tsconfig.lib.json"
    },
    {
      "path": "../runtime/tsconfig.lib.json"
    },
    {
      "path": "../contract/tsconfig.lib.json"
    }
  ]
}
