{
  "name": "@continuum-dev/vercel-ai-sdk-adapter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vercel-ai-sdk-adapter/src",
  "projectType": "library",
  "tags": ["scope:vercel-ai-sdk-adapter"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "packages/vercel-ai-sdk-adapter",
        "command": "vitest"
      }
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["^nx-release-publish"],
      "options": {
        "packageRoot": "dist/packages/vercel-ai-sdk-adapter"
      }
    }
  }
}
