{
  "name": "@continuum-dev/runtime",
  "version": "0.3.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Reconciliation engine for AI-generated view continuity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brytoncooper/continuum-dev.git",
    "directory": "packages/runtime"
  },
  "author": "Bryton Cooper",
  "keywords": [
    "continuum",
    "ai",
    "ui",
    "continuity",
    "reconciliation",
    "engine"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "@continuum-dev/source": "./src/index.ts",
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./validator": {
      "@continuum-dev/source": "./src/validator.ts",
      "types": "./validator.d.ts",
      "import": "./validator.js",
      "default": "./validator.js"
    },
    "./state-ops": {
      "@continuum-dev/source": "./src/lib/state-ops/index.ts",
      "types": "./state-ops.d.ts",
      "import": "./state-ops.js",
      "default": "./state-ops.js"
    }
  },
  "files": [
    "**/*.js",
    "**/*.d.ts",
    "**/*.d.ts.map",
    "README.md",
    "LICENSE*"
  ],
  "dependencies": {
    "@continuum-dev/contract": "^0.3.0",
    "@continuum-dev/protocol": "^0.3.0"
  },
  "nx": {
    "tags": [
      "scope:runtime"
    ]
  }
}
