{
  "name": "@continuum-dev/runtime",
  "version": "0.3.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Reconciliation engine for AI-generated view continuity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brytoncooper/continuum-dev.git",
    "directory": "packages/runtime"
  },
  "author": "Bryton Cooper",
  "keywords": [
    "continuum",
    "ai",
    "ui",
    "continuity",
    "reconciliation",
    "engine"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "@continuum-dev/source": "./src/index.ts",
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./validator": {
      "@continuum-dev/source": "./src/validator.ts",
      "types": "./validator.d.ts",
      "import": "./validator.js",
      "default": "./validator.js"
    },
    "./node-lookup": {
      "@continuum-dev/source": "./src/node-lookup.ts",
      "types": "./node-lookup.d.ts",
      "import": "./node-lookup.js",
      "default": "./node-lookup.js"
    },
    "./canonical-snapshot": {
      "@continuum-dev/source": "./src/canonical-snapshot.ts",
      "types": "./canonical-snapshot.d.ts",
      "import": "./canonical-snapshot.js",
      "default": "./canonical-snapshot.js"
    },
    "./value-write": {
      "@continuum-dev/source": "./src/value-write.ts",
      "types": "./value-write.d.ts",
      "import": "./value-write.js",
      "default": "./value-write.js"
    },
    "./view-stream": {
      "@continuum-dev/source": "./src/view-stream.ts",
      "types": "./view-stream.d.ts",
      "import": "./view-stream.js",
      "default": "./view-stream.js"
    },
    "./restore-candidates": {
      "@continuum-dev/source": "./src/restore-candidates.ts",
      "types": "./restore-candidates.d.ts",
      "import": "./restore-candidates.js",
      "default": "./restore-candidates.js"
    }
  },
  "files": [
    "**/*.js",
    "**/*.d.ts",
    "**/*.d.ts.map",
    "README.md",
    "LICENSE*"
  ],
  "dependencies": {
    "@continuum-dev/contract": "^0.3.0",
    "@continuum-dev/protocol": "^0.3.0"
  },
  "nx": {
    "tags": [
      "scope:runtime"
    ]
  }
}
