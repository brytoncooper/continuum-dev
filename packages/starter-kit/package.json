{
  "name": "@continuum-dev/starter-kit",
  "version": "0.3.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Slim React starter kit for Continuum with primitives, component map, styles, and session tooling",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brytoncooper/continuum-dev.git",
    "directory": "packages/starter-kit"
  },
  "author": "Bryton Cooper",
  "keywords": [
    "continuum",
    "ui",
    "react",
    "starter-kit",
    "primitives"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "@continuum-dev/source": "./src/index.ts",
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "**/*.js",
    "**/*.mjs",
    "**/*.d.ts",
    "**/*.d.mts",
    "**/*.d.ts.map",
    "README.md",
    "LICENSE*"
  ],
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@continuum-dev/core": "^0.3.0",
    "@continuum-dev/react": "^0.3.0"
  },
  "nx": {
    "tags": [
      "scope:starter-kit"
    ]
  }
}
