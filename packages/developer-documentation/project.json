{
  "name": "@continuum-dev/developer-documentation",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/developer-documentation/src",
  "projectType": "library",
  "tags": ["scope:developer-documentation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "packages/developer-documentation",
        "commands": [
          "node scripts/generate-corpus.mjs",
          "tsc --build --clean tsconfig.lib.json",
          "tsc --build tsconfig.lib.json"
        ]
      },
      "outputs": ["{workspaceRoot}/dist/packages/developer-documentation"]
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["^nx-release-publish"],
      "options": {
        "packageRoot": "dist/packages/developer-documentation"
      }
    }
  }
}
