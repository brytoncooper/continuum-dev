{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "../../dist/packages/contract",
    "tsBuildInfoFile": "../../dist/packages/contract/tsconfig.lib.tsbuildinfo",
    "types": ["node"],
    "emitDeclarationOnly": false
  },
  "exclude": [
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "include": ["src/**/*.ts"]
}
