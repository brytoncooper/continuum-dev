{
  "name": "@continuum-dev/angular",
  "private": true,
  "version": "0.1.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "Angular bindings for the Continuum continuity runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brytoncooper/continuum-dev.git",
    "directory": "packages/angular"
  },
  "author": "Bryton Cooper",
  "keywords": [
    "continuum",
    "ai",
    "ui",
    "continuity",
    "reconciliation",
    "angular",
    "signals"
  ],
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "@continuum/source": "./src/index.ts",
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "**/*.js",
    "**/*.d.ts",
    "**/*.d.ts.map",
    "README.md",
    "LICENSE*"
  ],
  "peerDependencies": {
    "@angular/core": ">=20.0.0",
    "@angular/common": ">=20.0.0",
    "@angular/forms": ">=20.0.0"
  },
  "dependencies": {
    "@continuum-dev/contract": "^0.1.4",
    "@continuum-dev/runtime": "^0.1.4",
    "@continuum-dev/session": "^0.1.4"
  },
  "nx": {
    "tags": [
      "scope:angular"
    ]
  }
}
