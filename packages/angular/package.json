{
  "name": "@continuum/angular",
  "version": "0.0.1",
  "description": "Angular bindings for the Continuum continuity runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CooperContinuum/continuum.git",
    "directory": "packages/angular"
  },
  "author": "CooperContinuum",
  "keywords": ["continuum", "ai", "ui", "continuity", "reconciliation", "angular", "signals"],
