{
  "name": "@continuum-dev/angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/angular/src",
  "projectType": "library",
  "tags": ["scope:angular"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "packages/angular",
        "commands": [
          "tsc --build --clean tsconfig.lib.json",
          "tsc --build tsconfig.lib.json"
        ]
      },
      "outputs": ["{workspaceRoot}/dist/packages/angular"]
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["^nx-release-publish"],
      "options": {
        "packageRoot": "dist/packages/angular"
      }
    }
  }
}
